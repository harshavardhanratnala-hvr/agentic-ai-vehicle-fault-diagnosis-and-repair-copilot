# Copy to .env and fill in real values. .env itself is gitignored — never commit real secrets.

# Agent LLM (tool-calling loop — classify -> retrieve -> generate). Plan allows either provider;
# set the one you're actually using and leave the other blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Supabase (pgvector RAG store + agent-run logging table).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string, for pgvector similarity queries / logging writes from the
# FastAPI backend (as opposed to Supabase's REST client).
DATABASE_URL=
